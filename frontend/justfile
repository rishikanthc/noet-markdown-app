# MarkdownLab — CLI workflow (no Xcode IDE required)
#
# Install `just` with: brew install just
# Then run e.g. `just run`, `just bench`, `just test`.

set shell := ["bash", "-uc"]

# Show available recipes (default).
default:
    @just --list

# Install build dependencies via Homebrew (Swift/macOS SDK come from Command Line Tools).
bootstrap:
    brew install zig cmake just

# Build the Zig MdCore core + cmark-gfm into one static library (.build/mdcore/lib).
core:
    ./scripts/build-core.sh

# Build the Swift executable (debug). Depends on the core library.
build: core
    swift build -c debug

# Build a release executable.
release: core
    swift build -c release

# Produce .build/MarkdownLab.app.
app: core
    ./scripts/bundle-app.sh

# Build and launch the editor. Optionally open a file: `just run sample.md`.
run file="": core
    #!/usr/bin/env bash
    set -euo pipefail
    ./scripts/bundle-app.sh
    if [[ -n "{{file}}" ]]; then
        abs="$(python3 -c 'import os,sys; print(os.path.abspath(sys.argv[1]))' "{{file}}")"
        open -n .build/MarkdownLab.app --args "$abs"
    else
        open -n .build/MarkdownLab.app
    fi

# Run the headless rendering benchmark (no GUI): times parse/render/convert across doc sizes.
bench: build
    #!/usr/bin/env bash
    set -euo pipefail
    BIN="$(swift build -c debug --show-bin-path)"
    "$BIN/MarkdownLab" --benchmark

# Run Swift tests and Zig core tests.
test:
    ./scripts/test-all.sh

# Format Swift sources (requires swift-format from the toolchain; no-op if absent).
fmt:
    #!/usr/bin/env bash
    set -euo pipefail
    if command -v swift-format >/dev/null 2>&1; then
        swift-format --in-place --recursive Sources Tests
    else
        echo "swift-format not found; skipping"
    fi

# Remove generated build output.
clean:
    rm -rf .build
    rm -rf Vendor/mdcore-zig/zig-out Vendor/mdcore-zig/.zig-cache
    rm -rf Vendor/mdcore-zig/vendor/cmark-gfm/build Vendor/mdcore-zig/vendor/cmark-gfm/install
